{
  "namespace": "hud",
  "hud_screen": {
    "modifications": [
      {
        "array_name": "controls",
        "operation": "insert_back",
        "value": {
          "flamed_fps_display@hud.fps_panel": {}
        }
      }
    ]
  },
  "fps_panel": {
    "type": "panel",
    "anchor_from": "top_left",
    "anchor_to": "top_left",
    "offset": [5, 5],
    "size": ["100%x", "10px"],
    "bindings": [
      {
        "binding_name": "#flamed_fps_enabled",
        "binding_name_override": "#visible",
        "binding_type": "global"
      }
    ],
    "controls": [
      {
        "fps_text": {
          "type": "label",
          "text": "§eFPS: #fps",
          "color": [1.0, 1.0, 1.0],
          "shadow": true,
          "bindings": [
            {
              "binding_name": "#fps",
              "binding_name_override": "#fps",
              "binding_type": "global"
            }
          ]
        }
      }
    ]
  }
}
